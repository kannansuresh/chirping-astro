---
import BaseLayout from './BaseLayout.astro';
import MathStyles from '../components/MathStyles.astro';
import type { Locale } from '../config';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  crumbs?: Array<{ label: string; href?: string }>;
  /** Load KaTeX CSS for this page only (no global load). */
  math?: boolean;
}

const { title, description, crumbs, math = false } = Astro.props;
---

<BaseLayout title={title} description={description} crumbs={crumbs ?? [{ label: title }]}>
  {math && <MathStyles />}
  <article class="px-1 py-6 sm:px-2 sm:py-8">
    <header class="mb-6">
      <h1 class="text-3xl leading-tight font-extrabold tracking-tight">{title}</h1>
      {description && <p class="text-base-content/70 mt-2">{description}</p>}
    </header>
    <div class="prose-chirpy max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
