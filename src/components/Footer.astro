---
import { SITE, REPO, type Locale } from '../config';
import { useTranslations } from '../i18n/utils';
import LanguageSwitcher from './islands/LanguageSwitcher.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer
  aria-label="Site Info"
  class="border-base-300 text-base-content/60 mt-10 flex flex-col gap-3 border-t py-6 text-sm lg:flex-row lg:items-center lg:justify-between"
>
  <p>
    © <time>{year}</time>{' '}
    <a href={SITE.author.url ?? '#'} rel="noopener" class="hover:text-primary">{SITE.author.name}</a
    >.{' '}
    {t('footer.copyright')}
  </p>
  <div class="flex items-center gap-3">
    <p>
      {t('footer.poweredBy')}{' '}
      <a href="https://astro.build" rel="noopener" class="hover:text-primary">Astro</a>{' '}
      · {t('footer.theme')}{' '}
      <a href={REPO.url} rel="noopener" class="hover:text-primary"> Chirping Astro </a>
    </p>
    <LanguageSwitcher locale={locale} />
  </div>
</footer>
