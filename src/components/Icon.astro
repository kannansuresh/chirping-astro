---
/**
 * Inline SVG icon set. All icons use the same 24x24 viewBox and
 * consistent stroke style (rounded, 1.75 width). Add a key in `paths`
 * and call `<Icon name="..."/>`.
 */

interface Props {
  name: string;
  size?: number;
  class?: string;
  ariaLabel?: string;
}

/**
 * Each entry is either a single `d` string (one path) or an array of
 * partial path attributes for icons with multiple shapes/strokes.
 */
type IconShape = string | Array<{ d: string; fill?: string; stroke?: string }>;

