---
/**
 * Icon component (Lucide via astro-icon).
 *
 * The rest of the codebase uses semantic names (e.g. "home", "stream",
 * "envelope") rather than Lucide's specific names. This component maps
 * those legacy keys onto the Lucide set so the call sites do not need
 * to change. Pass any non-mapped name (with the lucide prefix omitted)
 * and it will be rendered as-is.
 */

import { Icon as IconifyIcon } from 'astro-icon/components';

interface Props {
  name: string;
  size?: number;
  class?: string;
  ariaLabel?: string;
}

/** Map our internal/legacy icon names to the Lucide icon name. */
const aliases: Record<string, string> = {
  // Sidebar / nav
  home: 'home',
  stream: 'layers',
  folder: 'folder',
  tag: 'tag',
  archive: 'archive',
  info: 'info',

  // Topbar
  search: 'search',
  menu: 'menu',
  close: 'x',

  // Theme
  sun: 'sun',
  moon: 'moon',
  adjust: 'sun-moon',

  // Social
  github: 'github',
  twitter: 'twitter',
  rss: 'rss',
  envelope: 'mail',

  // Misc
  clock: 'clock',
  calendar: 'calendar-days',
  copy: 'copy',
  check: 'check',
  globe: 'globe',
  arrowUp: 'arrow-up',
  pin: 'pin',
  bird: 'bird',

  // Heading & TOC
  hash: 'hash',
  list: 'list',
  bookmark: 'bookmark',
  user: 'user',
  pencil: 'pencil',
  'chevron-down': 'chevron-down',
  'chevron-right': 'chevron-right',
  'chevron-up': 'chevron-up',
};

const { name, size = 18, class: className, ariaLabel } = Astro.props;
const lucideName = aliases[name] ?? name;
const role = ariaLabel ? 'img' : undefined;
---
<IconifyIcon
  name={`lucide:${lucideName}`}
  width={size}
  height={size}
  class={className}
  role={role}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
/>
