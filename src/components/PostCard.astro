---
import type { Locale } from '../config';
import { formatDate, isoDate } from '../i18n/utils';
import { type Post, postPath, heroImageSrc, shouldShowHero } from '../utils/posts';
import { Icon } from 'astro-icon/components';

interface Props {
  post: Post;
  locale: Locale;
}

const { post, locale } = Astro.props;
const href = postPath(post);
const heroSrc = heroImageSrc(post);
const hasImage = Boolean(heroSrc) && shouldShowHero(post);
const heroAlt = post.data.heroImageAlt ?? '';
---

<article class="chirpy-card">
  <a href={href} class:list={['chirpy-card-link', hasImage ? 'has-image' : '']}>
    {
      hasImage && (
        <div class="chirpy-card-image-wrap">
          <img
            src={heroSrc}
            alt={heroAlt}
            class="chirpy-card-image"
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }

    <div class:list={['chirpy-card-body', hasImage ? '' : 'full']}>
      <h2 class="chirpy-card-title">
        {post.data.title}
      </h2>

      <p class="text-base-content/70 mt-2 mb-3 line-clamp-2 text-base">
        {post.data.description}
      </p>

      <div class="text-base-content/55 mt-auto flex items-end justify-between gap-2 text-xs">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <span class="inline-flex items-center gap-1">
            <Icon name="lucide:clock" width={12} height={12} />
            <time datetime={isoDate(post.data.pubDate)}>
              {
                formatDate(post.data.pubDate, locale, {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })
              }
            </time>
          </span>
          {
            post.data.categories.length > 0 && (
              <span class="inline-flex items-center gap-1">
                <Icon name="lucide:folder" width={12} height={12} />
                <span>{post.data.categories.join(', ')}</span>
              </span>
            )
          }
        </div>

        {
          post.data.pinned && (
            <span
              class="text-primary inline-flex items-center gap-1"
              title="Pinned"
              aria-label="Pinned"
            >
              <Icon name="lucide:pin" width={14} height={14} />
            </span>
          )
        }
      </div>
    </div>
  </a>
</article>
