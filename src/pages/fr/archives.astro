---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, formatDate, isoDate } from '../../i18n/utils';
import { getPosts, groupByYearMonth, postPath } from '../../utils/posts';

const locale = 'fr';
const t = useTranslations(locale);
const posts = await getPosts(locale);
const groups = groupByYearMonth(posts, locale);
---

<BaseLayout
  title={t('archives.title')}
  pathWithoutLocale="/archives/"
  crumbs={[{ label: t('archives.title') }]}
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t('archives.title')}</h1>
  </header>
  {
    groups.length === 0 ? (
      <p class="text-base-content/70">{t('archives.empty')}</p>
    ) : (
      <div class="space-y-8">
        {groups.map((g) => {
          const yearPosts = g.months.flatMap((m) => m.posts);
          return (
            <section class="relative">
              {/* Vertical timeline line — centered over the dot column */}
              <div
                aria-hidden="true"
                class="bg-base-content/20 pointer-events-none absolute top-4 bottom-4 left-26 w-px"
              />
              <ol class="[&>li:nth-child(even)>*]:bg-base-200/40 grid grid-cols-[5rem_1.5rem_minmax(0,1fr)] items-center gap-x-3">
                {/* Year header row with hollow dot */}
                <li class="contents">
                  <div />
                  <div class="flex justify-center">
                    <span class="border-base-content/50 bg-base-100 relative z-10 block size-3.5 rounded-full border-2" />
                  </div>
                  <h2 class="py-2 text-2xl font-semibold tracking-tight">{g.year}</h2>
                </li>
                {/* Post rows */}
                {yearPosts.map((p) => (
                  <li class="group contents">
                    <time
                      datetime={isoDate(p.data.pubDate)}
                      class="text-base-content/60 group-hover:bg-base-200/70! flex items-baseline justify-end gap-1.5 py-2 pr-2"
                    >
                      <span class="text-base-content/80 text-lg font-medium tabular-nums">
                        {formatDate(p.data.pubDate, locale, { day: '2-digit' })}
                      </span>
                      <span class="text-xs tracking-wide uppercase">
                        {formatDate(p.data.pubDate, locale, { month: 'short' })}
                      </span>
                    </time>
                    <div class="group-hover:bg-base-200/70! flex justify-center py-2">
                      <span class="bg-base-content/50 relative z-10 block size-2.5 rounded-full" />
                    </div>
                    <a
                      href={postPath(p)}
                      class="link link-hover text-primary group-hover:bg-base-200/70! truncate py-2 pl-2"
                    >
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ol>
            </section>
          );
        })}
      </div>
    )
  }
</BaseLayout>
