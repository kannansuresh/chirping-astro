---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, withBase } from '../i18n/utils';

const locale = 'en';
const t = useTranslations(locale);
const pagefindBundle = withBase('/_pagefind/pagefind-ui.js');
const pagefindCss = withBase('/_pagefind/pagefind-ui.css');
---

<BaseLayout
  title={t('search.title')}
  pathWithoutLocale="/search/"
  narrow={true}
  crumbs={[{ label: t('search.title') }]}
>
  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t('search.title')}</h1>
    <p class="text-base-content/70">{t('search.placeholder')}</p>
  </header>
  <div data-pagefind-page-mount class="min-h-40">
    <p class="text-base-content/70 text-sm">{t('search.loading')}</p>
  </div>
</BaseLayout>

<script is:inline define:vars={{ locale, pagefindBundle, pagefindCss }}>
  async function init() {
    const mount = document.querySelector('[data-pagefind-page-mount]');
    if (!mount) return;
    if (!document.querySelector('link[data-pagefind-css]')) {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = pagefindCss;
      link.dataset.pagefindCss = 'true';
      document.head.appendChild(link);
    }
    await new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = pagefindBundle;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
    // eslint-disable-next-line no-undef
    new window.PagefindUI({
      element: mount,
      showSubResults: true,
      showImages: false,
      translations:
        locale === 'fr'
          ? {
              placeholder: 'Rechercher sur le site',
              clear_search: 'Effacer',
              load_more: 'Charger plus',
              search_label: 'Recherche',
              filters_label: 'Filtres',
              zero_results: 'Aucun résultat pour [SEARCH_TERM]',
              many_results: '[COUNT] résultats pour [SEARCH_TERM]',
              one_result: '[COUNT] résultat pour [SEARCH_TERM]',
              searching: 'Recherche de [SEARCH_TERM]…',
            }
          : undefined,
    });
  }
  init();
</script>
